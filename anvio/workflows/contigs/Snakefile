__credits__ = []
__license__ = "GPL 3.0"
__version__ = anvio.__version__
__maintainer__ = "Alon Shaiber"
__email__ = "alon.shaiber@gmail.com"

run = terminal.Run()

this_workflow_is_inherited_by_another = (
    False if "anvio/workflows/contigs" in str(workflow.included[0].abspath()) else True
)
if not this_workflow_is_inherited_by_another:
    # don't be confused, child. when things come to this point, the variable `config`
    # is already magically filled in by snakemake:
    M = ContigsDBWorkflow(
        argparse.Namespace(
            config=config,
            this_workflow_is_inherited_by_another=this_workflow_is_inherited_by_another,
        )
    )
    M.init()
    dirs_dict = M.dirs_dict


localrules:
    annotate_contigs_database,


rule contigs_target_rule:
    input:
        targets=expand(
            os.path.join(
                dirs_dict["CONTIGS_DIR"],
                "{group}-steps",
                "annotate_contigs_database.done",
            ),
            group=M.group_names,
        ),


# Workflow rule modules. Keep this order to preserve existing rule dependencies.
include: w.get_workflow_rule_file_path("contigs", "contigs_database.smk")
include: w.get_workflow_rule_file_path("contigs", "functional_annotation.smk")
include: w.get_workflow_rule_file_path("contigs", "gene_taxonomy.smk")
include: w.get_workflow_rule_file_path("contigs", "external_genomes.smk")


if "anvio/workflows/contigs" in str(workflow.included[0].abspath()):
    # check if all program dependencies are met. for this line to be effective,
    # there should be an initial dry run step (which is the default behavior of
    # the `WorkflowSuperClass`, so you are most likely covered).
    M.check_workflow_program_dependencies(workflow)
